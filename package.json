{
  "name": "quality-electrics-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static site for Quality Electrics, Glasgow",
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./assets/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./assets/css/style.css --watch",
    "build": "npm run generate && npm run build:css",
    "dev": "http-server . -p 4000 -c-1 -a 0.0.0.0"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.13"
  }
}
